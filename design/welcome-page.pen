                    0,
                    24
                  ],
                  "justifyContent": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "frVAM",
                      "name": "overviewTitle",
                      "fill": "$w:color-text",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "What you'll learn",
                      "lineHeight": 1.3,
                      "fontFamily": "Poppins",
                      "fontSize": "$w:font-size-h4",
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "ttEt1",
                      "name": "overviewBody",
                      "fill": "$w:color-text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "1. What IFS is\n2. Problems it tries to solve\n3. Benefits and extensibility\n4. Why it stays open and free",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": "$w:font-size-small"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "VVFpO",
                  "name": "whatCard",
                  "width": "fill_container",
                  "fill": "#f9f9f9",
                  "cornerRadius": "$w:radius-default",
                  "stroke": {
                    "thickness": 1
                  },
                  "layout": "vertical",
                  "gap": 12,
                  "padding": [
                    0,
                    24
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "uGeCB",
                      "name": "whatTitle",
                      "fill": "$w:color-text",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "What Is IFS",
                      "lineHeight": 1.3,
                      "fontFamily": "Poppins",
                      "fontSize": "$w:font-size-h3",
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "7anbK",
                      "name": "whatBody",
                      "fill": "$w:color-text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "IFS (Individual Freedom System) is a servant-architecture for governance. People keep sovereignty, delegate limited responsibilities to stewards, and can adjust or revoke that delegation in real time.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": "$w:font-size-body"
                    },
                    {
                      "type": "text",
                      "id": "JrSze",
                      "name": "whatNote",
                      "fill": "#26251e8c",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Power stays with people. Systems serve them.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": "$w:font-size-small",
                      "fontWeight": "500"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "uBfkU",
                  "name": "problemsCard",
                  "width": 360,
                  "fill": "#f9f9f9",
                  "cornerRadius": "$w:radius-default",
                  "stroke": {
                    "thickness": 1
                  },
                  "layout": "vertical",
                  "gap": 12,
                  "padding": [
                    0,
                    24
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "hsnmG",
                      "name": "problemsTitle",
                      "fill": "$w:color-text",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Problems IFS Tries to Solve",
                      "lineHeight": 1.3,
                      "fontFamily": "Poppins",
                      "fontSize": "$w:font-size-h3",
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "E1Fj7",
                      "name": "problemsBody",
                      "fill": "$w:color-text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "- Decisions happen far from the people affected.\n- Authority outlasts trust and consent.\n- Rules and public resource flows become opaque.\n- One-size rules ignore local reality.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": "$w:font-size-small"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "AeQqM",
                  "name": "benefitsCard",
                  "width": "fill_container",
                  "fill": "#f9f9f9",
                  "cornerRadius": "$w:radius-default",
                  "stroke": {
                    "thickness": 1
                  },
                  "layout": "vertical",
                  "gap": 12,
                  "padding": [
                    0,
                    24
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "aFZGe",
                      "name": "benefitsTitle",
                      "fill": "$w:color-text",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Benefits of IFS",
                      "lineHeight": 1.3,
                      "fontFamily": "Poppins",
                      "fontSize": "$w:font-size-h3",
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "sY9JQ",
                      "name": "benefitsBody",
                      "fill": "$w:color-text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "- Clear boundaries for consent and delegation.\n- Accountability through transparency and auditability.\n- Governance that scales with who is affected.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": "$w:font-size-small"
                    }
                  ]
                },
                {
