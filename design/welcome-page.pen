                    },
                    {
                      "type": "text",
                      "id": "UHbwu",
                      "name": "heroSlogan",
                      "fill": "$w:color-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Freedom for Humanity",
                      "lineHeight": 1.2,
                      "fontFamily": "Poppins",
                      "fontSize": "$w:font-size-h2",
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "YhGMR",
                      "name": "heroBody",
                      "fill": "$w:color-text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "IFS (Individual Freedom System) is an open standard for building systems where authority stays with individuals, delegation is specific and revocable, and rules plus resource flows stay transparent.",
