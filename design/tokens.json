{
  "version": "1.0",
  "description": "Source of truth for all design tokens. All .pen files must define these variables identically.",
  "variables": {
    "color-background": "#f2f1ed",
    "color-surface-primary": "#ebeae5",
    "color-surface-secondary": "#e6e5e0",
    "color-text": "#26251e",
    "color-text-secondary": "#26251e8c",
    "color-text-muted": "#26251e99",
    "color-accent": "#f54e00",
    "color-link-hover": "#f54e00",
    "color-error": "#cf2d56",
    "color-success": "#1f8a65",
    "color-border": "#26251e1a",
    "color-border-focus": "#26251e33",
    "font-family-heading": "Poppins",
    "font-family-body": "Inter",
    "font-family-code": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
    "font-size-h1": 40,
    "font-size-h2": 28,
    "font-size-h3": 22,
    "font-size-body": 16,
    "font-size-small": 14,
    "font-weight-heading-min": 500,
    "font-weight-heading-max": 600,
    "font-weight-body": 400,
    "line-height-min": 1.4,
    "line-height-max": 1.6,
    "spacing-base": 8,
    "spacing-8": 8,
    "spacing-12": 12,
    "spacing-16": 16,
    "spacing-24": 24,
    "spacing-32": 32,
    "radius-sm": 4,
    "radius-default": 8,
    "radius-pill": 9999,
    "border-width-default": 1,
    "button-primary-padding-x": 14,
    "button-primary-padding-y": 10,
    "button-secondary-padding-x": 10,
    "button-secondary-padding-y": 4,
    "card-padding": 16,
    "input-padding": 8,
    "layout-max-width": 1200,
    "duration-transition-min": 150,
    "duration-transition-max": 200
  }
}
